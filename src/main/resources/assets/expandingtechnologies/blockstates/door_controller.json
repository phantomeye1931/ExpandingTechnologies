{
  "multipart": [
    {
      "when": "north=true",
      "apply": {
        "model": "expandingtechnologies:block/door_controller_overlay",
        "y": 0
      }
    },
    {
      "when": "east=true",
      "apply": {
        "model": "expandingtechnologies:block/door_controller_overlay",
        "y": 90
      }
    },
    {
      "when": "south=true",
      "apply": {
        "model": "expandingtechnologies:block/door_controller_overlay",
        "y": 180
      }
    },
    {
      "when": "west=true",
      "apply": {
        "model": "expandingtechnologies:block/door_controller_overlay",
        "y": 270
      }
    }
  ]
}